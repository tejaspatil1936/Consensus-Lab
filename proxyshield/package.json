{
  "name": "@tejas_1936/proxyshield",
  "version": "1.0.4",
  "type": "module",
  "description": "High-performance reverse proxy and API gateway built from scratch with pure Node.js",
  "main": "index.js",
  "bin": {
    "proxyshield": "./cli.js"
  },
  "scripts": {
    "start": "node cli.js start",
    "dev": "node cli.js start --verbose",
    "benchmark": "node cli.js benchmark",
    "test": "node --test test/*.test.js",
    "test:backend": "node test-backend/server.js",
    "prepublishOnly": "npm test",
    "preversion": "npm test",
    "postversion": "git push && git push --tags"
  },
  "files": [
    "src/",
    "benchmark/",
    "scripts/",
    "cli.js",
    "index.js",
    "config.json",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "keywords": [
    "proxy",
    "reverse-proxy",
    "api-gateway",
    "rate-limiter",
    "waf",
    "firewall",
    "security",
    "ddos-protection",
    "middleware",
    "honeypot",
    "rate-limiting",
    "web-application-firewall",
    "xss-protection",
    "sql-injection",
    "brute-force-protection"
  ],
  "author": "Keith",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tejaspatil1936/Consensus-Lab.git"
  },
  "bugs": {
    "url": "https://github.com/tejaspatil1936/Consensus-Lab/issues"
  },
  "homepage": "https://github.com/tejaspatil1936/Consensus-Lab#readme"
}
